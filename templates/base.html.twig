<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        
        <title>{% block title %}Tech-Flow{% endblock %}</title>
        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body class="overflow-x-hidden antialiased text-gray-900 bg-gray-50 flex flex-col min-h-screen">        
        {{ include('partials/_navbar.html.twig') }}
        <div class="w-full grow flex flex-col">
            {# Messages de succès #}
            {% for message in app.flashes('success') %}
                <div class="mt-6 mb-4 p-4 bg-green-50 text-green-800 border border-green-200 rounded-lg font-medium flex items-center gap-3 shadow-sm" role="alert">
                    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            {# Messages d'erreur #}
            {% for message in app.flashes('danger') %}
                <div class="mt-6 mb-4 p-4 bg-red-50 text-red-800 border border-red-200 rounded-lg font-medium flex items-center gap-3 shadow-sm" role="alert">
                    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            {# Messages d'avertissement #}
            {% for message in app.flashes('warning') %}
                <div class="mt-6 mb-4 p-4 bg-yellow-50 text-yellow-800 border border-yellow-200 rounded-lg font-medium flex items-center gap-3 shadow-sm" role="alert">
                    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}
        
            {% block body %}{% endblock %}
        </div>
        {{ include('partials/_footer.html.twig') }}
        {# Cookie #}
        {{ include('partials/_cookie_banner.html.twig') }}
    </body>
</html>