{% extends 'base.html.twig' %}

{% block title %}Modifier la Catégorie{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 py-10">
    <div class="flex items-center gap-4 mb-8">
        <a href="{{ path('app_admin_category_index') }}" class="text-gray-600 hover:text-black transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg p-1" aria-label="Retour à la liste des catégories">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Modifier : {{ category.name }}</h1>
    </div>

    <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-200">
        {{ form_start(form) }}
            <div class="mb-6">
                {{ form_row(form.name) }}
            </div>
            <button class="bg-blue-600 text-white px-6 py-3 rounded-lg font-bold w-full hover:bg-blue-800 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">Mettre à jour</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}