{% extends 'base.html.twig' %}

{% block title %}Gestion des Utilisateurs{% endblock %}

{% block body %}
<main class="min-h-screen bg-gray-50 py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="mb-8">
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Utilisateurs inscrits</h1>
            <p class="text-sm text-gray-600 mt-1">Gestion des comptes clients et administrateurs.</p>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th scope="col" class="px-6 py-4 text-xs font-black text-gray-600 uppercase tracking-widest whitespace-nowrap">ID</th>
                            <th scope="col" class="px-6 py-4 text-xs font-black text-gray-600 uppercase tracking-widest whitespace-nowrap">Prénom & Nom</th>
                            <th scope="col" class="px-6 py-4 text-xs font-black text-gray-600 uppercase tracking-widest whitespace-nowrap">Email</th>
                            <th scope="col" class="px-6 py-4 text-xs font-black text-gray-600 uppercase tracking-widest whitespace-nowrap">Rôles</th>
                            <th scope="col" class="px-6 py-4 text-xs font-black text-gray-600 uppercase tracking-widest text-right whitespace-nowrap">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                    {% for user in users %}
                        <tr class="hover:bg-gray-50/50 transition-colors group">
                            <td class="px-6 py-4 text-gray-700 text-sm whitespace-nowrap">{{ user.id }}</td>
                            <td class="px-6 py-4 font-bold text-gray-900 whitespace-nowrap">{{ user.firstName }} {{ user.lastName }}</td>
                            <td class="px-6 py-4 text-gray-700 text-sm whitespace-nowrap">{{ user.email }}</td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex gap-1 flex-wrap" aria-label="Rôles de {{ user.firstName }}">
                                    {% for role in user.roles %}
                                        <span class="inline-block bg-gray-200 text-gray-800 text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wide">
                                            {{ role|replace({'ROLE_': ''}) }}
                                        </span>
                                    {% endfor %}
                                </div>
                            </td>
                            <td class="px-6 py-4 text-right whitespace-nowrap">
                                <div class="flex items-center justify-end gap-3 flex-nowrap">
                                    <a href="{{ path('app_admin_user_edit', {id: user.id}) }}" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-xs font-bold uppercase tracking-widest rounded-lg hover:bg-blue-700 transition-all shadow-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                                        Gérer
                                    </a>
                                    <form method="post" action="{{ path('app_admin_user_delete', {id: user.id}) }}" class="inline-block" onsubmit="return confirm('Attention : Cela supprimera définitivement le compte client. Continuer ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                        <button class="h-9 w-9 flex items-center justify-center text-red-700 bg-red-50 hover:bg-red-700 hover:text-white rounded-lg transition-all border border-red-200 active:scale-90 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" aria-label="Supprimer le compte de {{ user.firstName }}" title="Supprimer">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-6 py-20 text-center text-gray-500 font-medium">Aucun utilisateur trouvé.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>
{% endblock %}