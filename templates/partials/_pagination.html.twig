{% if pageCount > 1 %}
    <nav class="flex items-center justify-center space-x-2 my-8" aria-label="Pagination">
        
        {# Bouton Précédent #}
        {% if previous is defined %}
            <a href="{{ path(route, query|merge({(pageParameterName): previous})) }}" class="px-4 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 hover:text-gray-900 text-sm font-bold transition-all shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" aria-label="Page précédente">
                Précédent
            </a>
        {% else %}
            <span class="px-4 py-2 rounded-lg bg-gray-50 border border-gray-200 text-gray-400 text-sm font-bold cursor-not-allowed" aria-hidden="true">
                Précédent
            </span>
        {% endif %}

        {# Numéros de page #}
        <div class="hidden sm:flex items-center space-x-2">
            {% for page in pagesInRange %}
                {% if page == current %}
                    <span class="px-4 py-2 rounded-lg bg-blue-700 border border-blue-700 text-white text-sm font-black shadow-md" aria-current="page">
                        <span class="sr-only">Page </span>{{ page }}
                    </span>
                {% else %}
                    <a href="{{ path(route, query|merge({(pageParameterName): page})) }}" class="px-4 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 hover:text-blue-700 hover:border-blue-400 text-sm font-bold transition-all shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" aria-label="Aller à la page {{ page }}">
                        {{ page }}
                    </a>
                {% endif %}
            {% endfor %}
        </div>

        {# Bouton Suivant #}
        {% if next is defined %}
            <a href="{{ path(route, query|merge({(pageParameterName): next})) }}" class="px-4 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 hover:text-gray-900 text-sm font-bold transition-all shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" aria-label="Page suivante">
                Suivant
            </a>
        {% else %}
            <span class="px-4 py-2 rounded-lg bg-gray-50 border border-gray-200 text-gray-400 text-sm font-bold cursor-not-allowed" aria-hidden="true">
                Suivant
            </span>
        {% endif %}
        
    </nav>
{% endif %}