{% extends 'base.html.twig' %}

{% block title %}Nouveau Produit{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8 max-w-3xl">
    
    {# EN-TÊTE #}
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Ajouter un produit</h1>
        <a href="{{ path('app_admin_product_index') }}" class="text-blue-700 hover:text-blue-800 underline transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 rounded p-1">
            Retour au catalogue
        </a>
    </div>

    {# CONTENEUR DU FORMULAIRE #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden p-6">
        
        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
            
            {{ form_widget(form) }}

            {# BOUTON DE SOUMISSION #}
            <div class="pt-4 flex justify-end">
                <button type="submit" class="bg-green-600 hover:bg-green-800 text-white px-6 py-3 rounded-lg font-medium  transition-colors focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2">
                    Créer le produit et uploader les photos
                </button>
            </div>

        {{ form_end(form) }}
        
    </div>
</div>
{% endblock %}