{% extends 'base.html.twig' %}

{% block title %}Expédition - Tech Flow{% endblock %}

{% block body %}
<div class="max-w-6xl mx-auto px-4 py-10">
    <nav class="flex items-center text-sm font-medium mb-10 text-gray-600" aria-label="Étapes de commande">
        <span class="text-blue-700 font-bold" aria-current="step">1. Expédition</span>
        <span class="mx-3 text-gray-400" aria-hidden="true">/</span>
        <span>2. Confirmation</span>
        <span class="mx-3 text-gray-400" aria-hidden="true">/</span>
        <span>3. Paiement</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <div class="lg:col-span-8 space-y-10">
            
            <section aria-labelledby="address-selection-title">
                <h2 id="address-selection-title" class="text-2xl font-bold mb-6 text-gray-900">Sélectionnez une adresse de livraison</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {% for address in userAddresses %}
                        <div class="shadow-sm rounded-md p-5 bg-white border border-gray-200 hover:border-blue-500 hover:shadow-md transition-all relative">
                            <span class="text-[10px] font-bold uppercase tracking-wider text-gray-500 block mb-2">{{ address.label }}</span>
                            <p class="font-bold text-gray-900">{{ address.firstName }} {{ address.lastName }}</p>
                            <p class="text-sm text-gray-700">{{ address.address }}</p>
                            <p class="text-sm text-gray-700 mb-4">{{ address.postalCode }} {{ address.city }}, {{ address.country }}</p>
                            
                            <a href="{{ path('app_checkout_confirm', {id: address.id}) }}" 
                            class="inline-block bg-blue-700 hover:bg-blue-800 text-white text-sm font-medium py-2 px-4 rounded-md transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
                            aria-label="Utiliser cette adresse : {{ address.label }}">
                                Utiliser cette adresse
                            </a>
                        </div>
                    {% endfor %}
                </div>
            </section>

            <section x-data="{ open: {{ userAddresses|length > 0 ? 'false' : 'true' }} }">
                <button @click="open = !open" class="text-blue-700 hover:text-blue-900 hover:underline font-bold flex items-center mb-6 focus:outline-none focus:ring-2 focus:ring-blue-600 rounded p-1" :aria-expanded="open ? 'true' : 'false'">
                    <span class="mr-2" x-text="open ? '−' : '+'" aria-hidden="true"></span>
                    Saisir une nouvelle adresse d'expédition
                </button>

                <div x-show="open" x-transition class="bg-white rounded-md border border-gray-200 p-6 md:p-8 shadow-sm">
                    <h2 class="text-xl font-bold mb-1 text-gray-900">Saisir une nouvelle adresse</h2>
                    <p class="text-sm text-gray-600 mb-8">Les champs marqués d'un astérisque (*) sont obligatoires.</p>
                    
                    {{ form_start(addressForm, {'attr': {'class': 'space-y-6'}}) }}
                        
                        <div>
                            {{ form_label(addressForm.label, 'Nom de cette adresse (ex: Maison) *', {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                            {{ form_widget(addressForm.label, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none transition-shadow font-medium text-gray-900'}}) }}
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                {{ form_label(addressForm.firstName, 'Prénom *', {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                                {{ form_widget(addressForm.firstName, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none font-medium text-gray-900'}}) }}
                            </div>
                            <div>
                                {{ form_label(addressForm.lastName, 'Nom de famille *', {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                                {{ form_widget(addressForm.lastName, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none font-medium text-gray-900'}}) }}
                            </div>
                        </div>

                        <div>
                            {{ form_label(addressForm.phone, 'Numéro de téléphone *', {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                            {{ form_widget(addressForm.phone, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none font-medium text-gray-900'}}) }}
                            <p class="text-[11px] text-gray-600 mt-1 italic">Indispensable pour faciliter la livraison du colis.</p>
                        </div>

                        <div>
                            {{ form_label(addressForm.address, "Adresse complète *", {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                            {{ form_widget(addressForm.address, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none font-medium text-gray-900', 'placeholder': 'N° et nom de rue'}}) }}
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                {{ form_label(addressForm.postalCode, 'Code postal *', {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                                {{ form_widget(addressForm.postalCode, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none font-medium text-gray-900'}}) }}
                            </div>
                            <div>
                                {{ form_label(addressForm.city, 'Ville *', {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                                {{ form_widget(addressForm.city, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none font-medium text-gray-900'}}) }}
                            </div>
                        </div>

                        <div>
                            {{ form_label(addressForm.country, 'Pays/région *', {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                            {{ form_widget(addressForm.country, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none font-medium text-gray-900 bg-gray-50'}}) }}
                        </div>

                        <div class="pt-4 border-t border-gray-200">
                            <button type="submit" class="bg-blue-700 hover:bg-blue-900 text-white font-bold py-2.5 px-6 rounded-md shadow-md transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2">
                                Enregistrer cette adresse
                            </button>
                        </div>

                    {{ form_end(addressForm) }}
                </div>
            </section>
        </div>

        <aside class="lg:col-span-4">
            <div class="sticky top-6 rounded-md p-6 bg-white border border-gray-200 shadow-sm">
                <h2 class="text-lg font-bold mb-6 text-gray-900">Récapitulatif de commande</h2>
                
                <div class="space-y-4 mb-6 max-h-72 overflow-y-auto pr-2">
                    {% for item in items %}
                        <div class="flex gap-3">
                            <div class="w-14 h-14 bg-gray-50 rounded border border-gray-200 shrink-0 overflow-hidden flex items-center justify-center">
                                {% if item.product.productImages is not empty %}
                                    {% set firstImage = item.product.productImages|first %}
                                    <img src="{{ asset('uploads/images/' ~ firstImage.filename) }}" alt="Miniature de {{ item.product.name }}" class="w-full h-full object-cover mix-blend-multiply">
                                {% else %}
                                    <img src="{{ asset('uploads/images/ecran.jpg') }}" alt="Miniature par défaut pour {{ item.product.name }}" class="w-full h-full object-cover mix-blend-multiply">
                                {% endif %}
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-xs font-bold text-gray-900 truncate">{{ item.product.name }}</p>
                                <p class="text-[11px] text-gray-600">Qté : {{ item.quantity }}</p>
                            </div>
                            <p class="text-xs font-bold text-gray-900">{{ ((item.product.price * item.quantity) / 100)|number_format(2, ',', ' ') }}€</p>
                        </div>
                    {% endfor %}
                </div>

                <div class="border-t border-gray-200 pt-4 space-y-2">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-700">Articles :</span>
                        <span class="font-bold text-gray-900">{{ (total / 100)|number_format(2, ',', ' ') }}€</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-700">Livraison :</span>
                        <span class="text-gray-500 italic text-[11px]">Calculée après sélection</span>
                    </div>
                    <div class="flex justify-between text-xl font-bold pt-4 text-blue-700">
                        <span>Total TTC :</span>
                        <span>{{ (total / 100)|number_format(2, ',', ' ') }}€</span>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>
{% endblock %}