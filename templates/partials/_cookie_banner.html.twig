<dialog id="cookie-banner" open class="hidden fixed m-0 max-w-none bottom-0 left-0 w-full bg-gray-900 border-t border-gray-700 shadow-2xl z-50 p-4 sm:p-6 transition-transform" aria-labelledby="cookie-banner-title" aria-describedby="cookie-banner-desc">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        
        <div class="text-sm text-gray-300 text-center md:text-left">
            <p id="cookie-banner-desc">
                <strong id="cookie-banner-title" class="text-white">Respect de votre vie privée</strong><br>
                Nous utilisons des cookies essentiels pour assurer le bon fonctionnement du site, sécuriser vos transactions et analyser notre trafic.
                <a href="{{ path('app_legal_privacy') }}" class="text-blue-500 hover:text-blue-400 hover:underline font-medium whitespace-nowrap ml-1 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded p-1">En savoir plus.</a>
            </p>
        </div>
        
        <div class="flex items-center gap-3 shrink-0 w-full md:w-auto justify-center">
            <button onclick="declineCookies()" class="px-5 py-2.5 rounded-lg bg-gray-800 text-gray-300 hover:bg-gray-700 hover:text-white text-sm font-bold transition-colors w-full md:w-auto focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 focus:ring-offset-gray-900">
                Refuser
            </button>
            <button onclick="acceptCookies()" class="px-5 py-2.5 rounded-lg bg-blue-600 text-white hover:bg-blue-700 text-sm font-bold transition-colors shadow-lg w-full md:w-auto focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-900">
                Accepter
            </button>
        </div>
        
    </div>
</dialog>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const banner = document.getElementById('cookie-banner');
        const consent = localStorage.getItem('techflow_cookie_consent');
        
        if (!consent) {
            banner.classList.remove('hidden');
        }
    });

    function acceptCookies() {
        localStorage.setItem('techflow_cookie_consent', 'accepted');
        document.getElementById('cookie-banner').classList.add('hidden');
    }

    function declineCookies() {
        localStorage.setItem('techflow_cookie_consent', 'declined');
        document.getElementById('cookie-banner').classList.add('hidden');
    }
</script>