{% extends 'base.html.twig' %}

{% block title %}Inscription | Tech Flow{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-10">
    <div class="w-full max-w-md p-8 bg-white border border-gray-200 rounded-xl shadow-xl">
        
        <h1 class="text-2xl font-bold text-center text-gray-900 mb-8 uppercase tracking-wide">Créer un compte</h1>

        {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
            
            {% if not registrationForm.vars.valid %}
                <div class="mb-4 text-red-600 text-sm font-bold text-center" role="alert">
                    {{ form_errors(registrationForm) }}
                </div>
            {% endif %}

            <div class="flex gap-4 mb-5">
                <div class="w-1/2">
                    {{ form_label(registrationForm.firstName, null, {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                    <div class="text-red-600 text-sm mb-1 font-bold">{{ form_errors(registrationForm.firstName) }}</div>
                    {{ form_widget(registrationForm.firstName, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-gray-900'}}) }}
                </div>
                <div class="w-1/2">
                    {{ form_label(registrationForm.lastName, null, {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                    <div class="text-red-600 text-sm mb-1 font-bold">{{ form_errors(registrationForm.lastName) }}</div>
                    {{ form_widget(registrationForm.lastName, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-gray-900'}}) }}
                </div>
            </div>

            <div class="mb-5">
                {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                <div class="text-red-600 text-sm mb-1 font-bold">{{ form_errors(registrationForm.email) }}</div>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-gray-900'}}) }}
            </div>

            <div class="mb-6">
                {{ form_label(registrationForm.plainPassword, null, {'label_attr': {'class': 'block text-sm font-bold text-gray-900 mb-1'}}) }}
                <div class="text-red-600 text-sm mb-1 font-bold">{{ form_errors(registrationForm.plainPassword) }}</div>
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full border border-gray-300 rounded-md py-2 px-3 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-gray-900'}}) }}
            </div>

            <div class="mb-8">
                <div class="flex items-start space-x-3">
                    <div class="flex items-center h-5">
                        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-4 h-4 text-blue-600 bg-white border-gray-300 rounded focus:ring-blue-500 focus:ring-2 cursor-pointer'}}) }}
                    </div>
                    <label for="{{ registrationForm.agreeTerms.vars.id }}" class="text-sm text-gray-700 cursor-pointer">
                        J'accepte les <a href="{{ path('app_legal_cgv') }}" target="_blank" class="text-blue-700 hover:text-blue-900 hover:underline font-bold focus:outline-none focus:ring-2 focus:ring-blue-600 rounded p-1">CGV</a> et la <a href="{{ path('app_legal_privacy') }}" target="_blank" class="text-blue-700 hover:text-blue-900 hover:underline font-bold focus:outline-none focus:ring-2 focus:ring-blue-600 rounded p-1">Politique de confidentialité</a> *
                    </label>
                </div>
                <div class="text-red-600 text-sm mt-1 font-bold">{{ form_errors(registrationForm.agreeTerms) }}</div>
            </div>

            <button type="submit" class="w-full py-2.5 bg-blue-700 hover:bg-blue-900 text-white font-bold rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2">
                Rejoindre Tech Flow
            </button>

            <p class="mt-6 text-center text-sm text-gray-600">
                Déjà inscrit ? <a href="{{ path('app_login') }}" class="text-blue-700 hover:text-blue-900 hover:underline font-bold focus:outline-none focus:ring-2 focus:ring-blue-600 rounded p-1">Se connecter</a>
            </p>
            
        {{ form_end(registrationForm) }}

    </div>
</div>
{% endblock %}