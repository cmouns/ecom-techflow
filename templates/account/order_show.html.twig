{% extends 'base.html.twig' %}

{% block title %}Commande {{ order.reference }}{% endblock %}

{% block body %}
<main class="bg-gray-50 min-h-screen py-10">
    <div class="container mx-auto px-4 max-w-4xl">
        
        <div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Commande {{ order.reference }}</h1>
                <p class="text-gray-600 mt-1">Passée le {{ order.createdAt|date('d/m/Y à H:i') }}</p>
            </div>
            <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                <a href="{{ path('app_account_order_pdf', {'reference': order.reference}) }}" class="bg-yellow-600 hover:bg-yellow-800 text-white font-bold py-2 px-4 rounded-lg text-sm flex items-center justify-center whitespace-nowrap transition-colors focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    Facture PDF
                </a>
                <a href="{{ path('app_account_orders') }}" class="text-blue-600 hover:text-blue-800 font-bold text-sm underline text-center whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-blue-500 rounded p-1">
                    Retour aux commandes
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
                <h2 class="text-gray-600 font-bold text-sm uppercase mb-2">Statut de la commande</h2>
                {% if order.status == 'PAID' %}
                    <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-bold inline-block">Payée</span>
                {% else %}
                    <span class="bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full text-sm font-bold inline-block">En attente</span>
                {% endif %}
            </div>

            <div class="bg-white p-6 rounded-lg shadow border border-gray-200 md:col-span-2">
                <h2 class="text-gray-600 font-bold text-sm uppercase mb-2">Adresse de livraison</h2>
                <p class="text-gray-800 leading-relaxed">{{ order.deliveryAddress|nl2br }}</p>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
            <div class="bg-gray-100 px-6 py-4 border-b border-gray-200">
                <h2 class="font-bold text-gray-800 text-lg">Détail des articles</h2>
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-sm font-bold text-gray-700 whitespace-nowrap">Produit</th>
                            <th scope="col" class="px-6 py-3 text-sm font-bold text-gray-700 text-center whitespace-nowrap">Quantité</th>
                            <th scope="col" class="px-6 py-3 text-sm font-bold text-gray-700 text-right whitespace-nowrap">Prix Unitaire</th>
                            <th scope="col" class="px-6 py-3 text-sm font-bold text-gray-700 text-right whitespace-nowrap">Total</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        {% for item in items %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 text-gray-900 font-bold whitespace-nowrap">{{ item.productName }}</td>
                                <td class="px-6 py-4 text-center text-gray-600 whitespace-nowrap">x{{ item.quantity }}</td>
                                <td class="px-6 py-4 text-right text-gray-600 whitespace-nowrap">{{ (item.productPrice / 100)|number_format(2, ',', ' ') }} €</td>
                                <td class="px-6 py-4 text-right font-bold text-gray-900 whitespace-nowrap">{{ ((item.productPrice * item.quantity) / 100)|number_format(2, ',', ' ') }} €</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            
            <div class="bg-gray-50 p-6 border-t border-gray-200 flex justify-end">
                <div class="text-right">
                    <p class="text-gray-600 text-sm mb-1">Total payé</p>
                    <p class="text-2xl font-bold text-blue-600">{{ (order.totalPrice / 100)|number_format(2, ',', ' ') }} €</p>
                </div>
            </div>
        </div>

    </div>
</main>
{% endblock %}