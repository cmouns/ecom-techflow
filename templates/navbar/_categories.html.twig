<ul class="flex items-center space-x-8 h-12" aria-label="Menu des catégories">
    <li>
        <a href="{{ path('app_product_index') }}" class="text-gray-300 hover:text-white text-sm font-medium whitespace-nowrap transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 rounded p-1" aria-current="{{ app.request.attributes.get('_route') == 'app_product_index' and not app.request.query.get('category') ? 'page' : 'false' }}">
            Tous les produits
        </a>
    </li>

    {% for category in categories %}
        <li>
            <a href="{{ path('app_product_index', {category: category.slug}) }}" class="text-gray-300 hover:text-white text-sm font-medium whitespace-nowrap transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 rounded p-1" aria-current="{{ app.request.query.get('category') == category.slug ? 'page' : 'false' }}">
                {{ category.name }}
            </a>
        </li>
    {% endfor %}
</ul>