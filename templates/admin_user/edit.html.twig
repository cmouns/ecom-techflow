{% extends 'base.html.twig' %}

{% block title %}Modifier l'utilisateur{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 py-10">
    <div class="flex items-center gap-4 mb-8">
        <a href="{{ path('app_admin_user_index') }}" class="text-gray-600 hover:text-black transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg p-1" aria-label="Retour à la liste des utilisateurs">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Gérer les rôles de {{ user.firstName }} {{ user.lastName }}</h1>
    </div>

    <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-200">
        <div class="mb-8 p-4 bg-gray-50 border border-gray-200 rounded-lg">
            <p class="text-sm text-gray-600 mb-1">Email du compte</p>
            <p class="font-bold text-gray-900">{{ user.email }}</p>
        </div>

        {{ form_start(form) }}
            <div class="mb-8 space-y-3">
                <fieldset>
                    <legend class="sr-only">{{ form_label(form.roles) }}</legend>
                    <div aria-hidden="true" class="text-sm font-medium text-gray-700 mb-2">{{ form_label(form.roles) }}</div>
                    {% for child in form.roles %}
                        <div class="flex items-start">
                            {{ form_widget(child, {'attr': {'class': 'focus:ring-blue-500'}}) }}
                            {{ form_label(child, null, {'label_attr': {'class': 'text-sm font-medium text-gray-700 cursor-pointer'}}) }}
                        </div>
                    {% endfor %}
                </fieldset>
            </div>
            <button class="bg-blue-600 text-white px-6 py-3 rounded-lg font-bold w-full hover:bg-blue-800 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">Enregistrer les modifications</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}