{% extends 'base.html.twig' %}

{% block title %}Mon Compte{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-semibold text-gray-900 mb-8">Mon espace personnel</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        
        {# MES INFORMATIONS #}
        <section class="bg-white rounded-xl shadow-xl border border-gray-200 overflow-hidden flex flex-col" aria-labelledby="heading-infos">
            <div class="p-6 bg-gray-50 flex justify-between items-center border-b border-gray-200">
                <h2 id="heading-infos" class="text-lg font-semibold text-gray-900">Mes informations</h2>
                <a href="{{ path('app_account_edit') }}" class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-semibold hover:bg-blue-700 transition-colors shadow-sm focus:ring-2 focus:ring-blue-500 focus:outline-none focus:ring-offset-2" aria-label="Modifier mes informations personnelles">Modifier</a>
            </div>
            <div class="p-6 flex-1 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-xs font-semibold text-gray-600 uppercase tracking-wider mb-1.5">Prénom</p>
                        <div class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2.5 text-gray-900 font-medium">
                            {{ app.user.firstName }}
                        </div>
                    </div>
                    <div>
                        <p class="text-xs font-semibold text-gray-600 uppercase tracking-wider mb-1.5">Nom</p>
                        <div class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2.5 text-gray-900 font-medium">
                            {{ app.user.lastName }}
                        </div>
                    </div>
                </div>
                <div>
                    <p class="text-xs font-semibold text-gray-600 uppercase tracking-wider mb-1.5">Adresse Email</p>
                    <div class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2.5 text-gray-900 font-medium break-all">
                        {{ app.user.email }}
                    </div>
                </div>
            </div>
        </section>

        {# SÉCURITÉ #}
        <section class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col" aria-labelledby="heading-security">
            <div class="p-6 border-b border-gray-200 bg-gray-50 flex justify-between items-center">
                <h2 id="heading-security" class="text-lg font-semibold text-gray-900">Sécurité</h2>
                <a href="{{ path('app_account_password') }}" class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-semibold hover:bg-blue-700 transition-colors shadow-sm focus:ring-2 focus:ring-blue-500 focus:outline-none focus:ring-offset-2" aria-label="Modifier mon mot de passe">Modifier</a>
            </div>
            <div class="p-6 flex-1 flex flex-col justify-center">
                <p class="text-xs font-semibold text-gray-600 uppercase tracking-wider mb-1.5">Mot de passe actuel</p>
                <div class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2.5 flex items-center justify-between">
                    <span class="text-gray-900 font-medium tracking-widest mt-1" aria-label="Mot de passe masqué">••••••••••••••••</span>
                    <svg class="w-5 h-5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </div>
                <p class="text-xs text-gray-600 mt-3">Votre compte est protégé par un mot de passe chiffré.</p>
            </div>
        </section>
    </div>

    {# HISTORIQUE DES COMMANDES #}
    <section class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-8" aria-labelledby="heading-orders">
        <div class="p-6 border-b border-gray-200 bg-gray-50 flex justify-between items-center flex-wrap gap-4">
            <div>
                <h2 id="heading-orders" class="text-lg font-semibold text-gray-900">Historique des achats</h2>
                <p class="text-sm text-gray-600 mt-1">Consultez vos commandes, leur statut et téléchargez vos factures.</p>
            </div>
            <a href="{{ path('app_account_orders') }}" class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-semibold hover:bg-blue-700 transition-colors shadow-sm focus:ring-2 focus:ring-blue-500 focus:outline-none focus:ring-offset-2" aria-label="Voir tout l'historique des achats">Voir tout</a>
        </div>
        <div class="p-6 flex items-center gap-5">
            <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 shrink-0 border border-blue-100" aria-hidden="true">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
            </div>
            <div>
                <p class="text-base font-semibold text-gray-900">Mes Commandes</p>
                <p class="text-sm text-gray-600">Accédez à vos reçus et au suivi de vos livraisons en quelques clics.</p>
            </div>
        </div>
    </section>

    {# DROIT A L'OUBLIE #}
    <section class="bg-red-50 border border-red-200 rounded-xl p-6 relative overflow-hidden" aria-labelledby="heading-danger">
        <div class="relative z-10">
            <h2 id="heading-danger" class="text-red-800 font-semibold mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                Zone de danger
            </h2>
            <p class="text-sm text-red-700 mb-5">La suppression de votre compte est définitive. Toutes vos données personnelles et historiques de commandes seront effacés de nos serveurs conformément au RGPD.</p>
            <form method="post" action="{{ path('app_account_delete') }}" onsubmit="return confirm('Êtes-vous absolument sûr de vouloir supprimer votre compte ? Cette action est irréversible.');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_account' ~ app.user.id) }}">
                <button type="submit" class="bg-red-600 text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-red-700 transition-colors shadow-sm flex items-center gap-2 focus:ring-2 focus:ring-red-500 focus:outline-none focus:ring-offset-2 focus:ring-offset-red-50">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    <span>Supprimer définitivement mon compte</span>
                </button>
            </form>
        </div>
    </section>
</div>
{% endblock %}