{% extends 'base.html.twig' %}

{% block title %}Paiement annulé{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-20 text-center">
    <h1 class="text-4xl font-bold text-red-600 mb-4" role="alert">Paiement annulé</h1>
