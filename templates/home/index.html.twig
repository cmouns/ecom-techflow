{% extends 'base.html.twig' %}

{% block title %}Accueil | Tech Flow{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex flex-col">

    {# HERO SECTION #}
    <div class="bg-gray-900">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 sm:pb-24 lg:pb-32">
            <div class="text-center max-w-3xl mx-auto mt-12 sm:mt-16 md:mt-20">
                <h1 class="text-4xl tracking-tight font-extrabold text-white sm:text-5xl md:text-6xl">
                    <span class="block">L'équipement des</span>
                    <span class="block text-blue-600">vrais professionnels.</span>
                </h1>
                <p class="mt-3 text-base text-gray-200 sm:mt-5 sm:text-lg md:mt-5 md:text-xl">
                    Découvrez notre sélection de matériel informatique haut de gamme. Conçu pour la performance, la fiabilité et repousser vos limites.
                </p>
                <div class="mt-8 flex justify-center">
                    <div class="rounded-md shadow">
                        <a href="{{ path('app_product_index') }}" class="w-full flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-lg text-white bg-blue-700 hover:bg-blue-800 md:py-4 md:text-lg transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 focus:ring-offset-gray-900">
                            Voir le catalogue
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
        
    {# DERNIERS ARRIVAGES #}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="flex justify-between items-end mb-8">
            <h2 class="text-2xl font-bold text-gray-900 tracking-tight">Derniers arrivages</h2>
            <a href="{{ path('app_product_index') }}" class="text-sm font-medium text-blue-700 hover:text-blue-900 focus:outline-none focus:ring-2 focus:ring-blue-600 rounded p-1">Tout voir</a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {% for product in products %}
                <div class="bg-white border border-gray-200 rounded-lg shadow-sm flex flex-col group p-4 hover:shadow-md transition-shadow">
                    
                    <div class="aspect-4/3 w-full rounded-md bg-gray-50 flex items-center justify-center overflow-hidden mb-4 relative">
                        {% if product.productImages is not empty %}
                            {% set firstImage = product.productImages|first %}
                            {% set imageUrl = asset('uploads/images/' ~ firstImage.filename) %}
                        {% else %}
                            {% set imageUrl = asset('uploads/images/ecran.jpg') %}
                        {% endif %}
                        <img src="{{ imageUrl }}" alt="{{ product.name }}" class="object-contain w-full h-full mix-blend-multiply transform group-hover:scale-105 transition-transform duration-500 ease-out">
                    </div>

                    <div class="text-sm font-bold text-gray-900 truncate">{{ product.name }}</div>
                    <div class="text-blue-700 font-bold mt-2"><span class="sr-only">Prix : </span>{{ (product.price / 100)|number_format(2, ',', ' ') }}€</div>
                    <a href="{{ path('app_product_show', { slug: product.slug }) }}" aria-label="Voir les détails du produit : {{ product.name }}" class="mt-4 text-center bg-blue-700 text-white text-xs font-bold py-2.5 rounded-lg hover:bg-blue-800 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2">Voir</a>
                </div>
            {% else %}
                <p class="text-gray-600 col-span-4 text-center py-10 font-medium">Aucun produit pour le moment.</p>
            {% endfor %}
        </div>
    </div>

    {# SECTION RÉASSURANCE #}
    <div class="bg-white border-y border-gray-200 py-16 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
                <div class="flex flex-col items-center">
                    <div class="w-12 h-12 bg-blue-50 text-blue-700 rounded-full flex items-center justify-center mb-4" aria-hidden="true">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2">Livraison rapide</h3>
                    <p class="text-sm text-gray-600">Expédition sous 24h pour toutes les commandes passées avant midi.</p>
                </div>
                <div class="flex flex-col items-center">
                    <div class="w-12 h-12 bg-blue-50 text-blue-700 rounded-full flex items-center justify-center mb-4" aria-hidden="true">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2">Garantie 2 ans</h3>
                    <p class="text-sm text-gray-600">Tous nos équipements sont garantis pièces et main d'œuvre pendant 2 ans minimum.</p>
                </div>
                <div class="flex flex-col items-center">
                    <div class="w-12 h-12 bg-blue-50 text-blue-700 rounded-full flex items-center justify-center mb-4" aria-hidden="true">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2">Support dédié</h3>
                    <p class="text-sm text-gray-600">Une équipe d'experts tech à votre écoute 6j/7 pour vous accompagner.</p>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}