{% extends 'base.html.twig' %}

{% block title %}Inscription | Tech Flow{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-gray-600 px-4 py-10">
    <div class="w-full max-w-md p-8 bg-gray-800 border border-gray-700 rounded-xl shadow-2xl">
        
        <h1 class="text-2xl font-bold text-center text-white mb-8 uppercase tracking-wide">Créer un compte</h1>

        {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
            
            {% if not registrationForm.vars.valid %}
                <div class="mb-4 text-red-400 text-sm font-bold text-center" role="alert">
                    {{ form_errors(registrationForm) }}
                </div>
            {% endif %}

            <div class="flex gap-4 mb-5">
                <div class="w-1/2">
                    {{ form_label(registrationForm.firstName, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                    <div class="text-red-400 text-sm mb-1 font-bold">{{ form_errors(registrationForm.firstName) }}</div>
                    {{ form_widget(registrationForm.firstName, {'attr': {'class': 'w-full px-4 py-2.5 bg-gray-700 border border-gray-600 text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors sm:text-sm placeholder:text-gray-400'}}) }}
                </div>
                <div class="w-1/2">
                    {{ form_label(registrationForm.lastName, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                    <div class="text-red-400 text-sm mb-1 font-bold">{{ form_errors(registrationForm.lastName) }}</div>
                    {{ form_widget(registrationForm.lastName, {'attr': {'class': 'w-full px-4 py-2.5 bg-gray-700 border border-gray-600 text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors sm:text-sm placeholder:text-gray-400'}}) }}
                </div>
            </div>

            <div class="mb-5">
                {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                <div class="text-red-400 text-sm mb-1 font-bold">{{ form_errors(registrationForm.email) }}</div>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full px-4 py-2.5 bg-gray-700 border border-gray-600 text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors sm:text-sm placeholder:text-gray-400'}}) }}
            </div>

            <div class="mb-6">
                {{ form_label(registrationForm.plainPassword, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                <div class="text-red-400 text-sm mb-1 font-bold">{{ form_errors(registrationForm.plainPassword) }}</div>
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full px-4 py-2.5 bg-gray-700 border border-gray-600 text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors sm:text-sm placeholder:text-gray-400'}}) }}
            </div>

            <div class="mb-8">
                <div class="flex items-start space-x-3">
                    <div class="flex items-center h-5">
                        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-4 h-4 text-blue-500 bg-gray-700 border-gray-600 rounded focus:ring-blue-500 focus:ring-2 cursor-pointer'}}) }}
                    </div>
                    <label for="{{ registrationForm.agreeTerms.vars.id }}" class="text-sm text-gray-300 cursor-pointer">
                        J'accepte les <a href="{{ path('app_legal_cgv') }}" target="_blank" class="text-blue-400 hover:text-blue-300 hover:underline font-medium focus:outline-none focus:ring-2 focus:ring-blue-500 rounded p-1">CGV</a> et la <a href="{{ path('app_legal_privacy') }}" target="_blank" class="text-blue-400 hover:text-blue-300 hover:underline font-medium focus:outline-none focus:ring-2 focus:ring-blue-500 rounded p-1">Politique de confidentialité</a> *
                    </label>
                </div>
                <div class="text-red-400 text-sm mt-1 font-bold">{{ form_errors(registrationForm.agreeTerms) }}</div>
            </div>

            <button type="submit" class="w-full py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-800">
                Rejoindre Tech Flow
            </button>

            <p class="mt-6 text-center text-sm text-gray-400">
                Déjà inscrit ? <a href="{{ path('app_login') }}" class="text-blue-500 hover:text-blue-400 font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 rounded p-1">Se connecter</a>
            </p>
            
        {{ form_end(registrationForm) }}

    </div>
</div>
{% endblock %}