{% extends 'base.html.twig' %}

{% block title %}Connexion | Tech Flow{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-gray-600 px-4">
    
    <div class="w-full max-w-md p-8 bg-gray-800 border border-gray-700 rounded-xl shadow-2xl">
        
        <h1 class="text-2xl font-bold text-center text-white tracking-wide mb-8">
            TECH FLOW
        </h1>

        <form method="post">
            {% if error %}
                <div class="mb-6 p-4 bg-red-900/50 border border-red-800 text-red-200 rounded-lg text-sm" role="alert">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {# Champ Email #}
            <div class="mb-5">
                <label for="username" class="block text-sm font-medium text-gray-300 mb-2">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" 
                    class="w-full px-4 py-2.5 bg-gray-700 border border-gray-600 text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors sm:text-sm placeholder:text-gray-400" 
                    autocomplete="email" required autofocus placeholder="nom@exemple.fr">
            </div>

            {# Champ Password #}
            <div class="mb-6">
                <label for="password" class="block text-sm font-medium text-gray-300 mb-2">Mot de passe</label>
                <input type="password" name="_password" id="password" 
                    class="w-full px-4 py-2.5 bg-gray-700 border border-gray-600 text-white rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors sm:text-sm placeholder:text-gray-400" 
                    autocomplete="current-password" required placeholder="••••••••">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            {# Bouton de connexion #}
            <button type="submit" 
                class="w-full py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors mt-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-800">
                Se connecter
            </button>

            {# Lien d'inscription #}
            <div class="mt-6 text-center">
                <p class="text-sm text-gray-400">
                    Pas encore de compte ? 
                    <a href="{{ path('app_register') }}" class="text-blue-500 hover:text-blue-400 font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 rounded p-1">
                        Créer un compte
                    </a>
                </p>
            </div>
        </form>
    </div>
</div>
{% endblock %}